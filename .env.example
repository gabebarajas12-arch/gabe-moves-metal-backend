# Gabe Moves Metal — Lead Engine Environment Variables
# Copy this file to .env and fill in your values
# See META_SETUP_GUIDE.md for how to get these

# Meta Developer App credentials
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here
META_PAGE_ACCESS_TOKEN=your_long_lived_page_access_token_here
META_VERIFY_TOKEN=gabe_moves_metal_2025

# Your Facebook Page ID (Gabe Moves Metal)
PAGE_ID=61575074716398

# Your Instagram Business Account ID
IG_ACCOUNT_ID=your_ig_account_id_here

# Your public webhook URL (use ngrok for testing)
WEBHOOK_URL=https://your-domain.com/webhook

# Server port
PORT=3000